# Backend connection
BACKEND_URL=wss://api.iyiddencommander.com/ws/agent

# Auth — must match AGENT_API_KEY in backend's .env
AGENT_API_KEY=

# Identifies this agent in logs (e.g. "leosh-laptop")
AGENT_NAME=leosh-laptop

# Heartbeat frequency in seconds
HEARTBEAT_INTERVAL=30

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
