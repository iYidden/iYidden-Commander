# Copy to .env and fill in. Never commit .env.

# Server bind
HOST=0.0.0.0
PORT=8000

# Required: random URL-safe string, >= 32 bytes. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Required for the dev-machine agent's WS auth. Generate the same way.
AGENT_API_KEY=

# Anthropic — only needed for step 8 (emergency summaries). Leave blank in step 1.
ANTHROPIC_API_KEY=

# SQLite path. Relative paths resolve from backend/.
DB_PATH=./iyidden.db

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Public base URL — used to build mashpia-setup links. e.g. https://commander.example.com
PUBLIC_BASE_URL=http://localhost:8000
